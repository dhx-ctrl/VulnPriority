
DEFECTDOJO_URL=http://host.docker.internal:8080
# If running backend directly on Windows/localhost, you can use:
# DEFECTDOJO_URL=http://127.0.0.1:8080
DEFECTDOJO_API_KEY=replace_with_your_defectdojo_api_key
DEFECTDOJO_PRODUCT_ID=

# This is the first admin account used to log in before approving users.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace_with_admin_password

# Long local API token used by the frontend/backend.
# Replace with a long random value in your real .env.
API_AUTH_TOKEN=replace_with_long_random_api_token

# Vite dev server + possible static local server
DASHBOARD_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500

AI_CLEAN_MODEL_DIR=model_output_FINAL_clean_minimal_features
AI_RANKER_MODEL_DIR=model_output_EPSS_operational_ranker
