# product.env — Juice Shop
#
# App-specific configuration for OWASP Juice Shop.
# Sourced by run_pipeline.sh.  Values here are defaults; environment
# variables set by the wrapper workflow override these.

# ── Target identity ──────────────────────────────────────────────────────
APP_NAME="juice-shop"
APP_URL="http://juice-shop:3000"
APP_PORT="3000"
CONTAINER_PORT="3000"

# ── Docker image ─────────────────────────────────────────────────────────
DOCKER_IMAGE_NAME="bkimminich/juice-shop"
DOCKER_IMAGE_SOURCE="pull"

# ── Scanner defaults (overridden by workflow_dispatch inputs) ────────────
# Uses ${VAR:-default} so environment variables from the wrapper workflow
# take precedence over these defaults.
ENABLE_SEMGREP="${ENABLE_SEMGREP:-true}"
ENABLE_TRIVY_FS="${ENABLE_TRIVY_FS:-true}"
ENABLE_TRIVY_IMAGE="${ENABLE_TRIVY_IMAGE:-true}"
ENABLE_ZAP="${ENABLE_ZAP:-true}"

# ── Semgrep extra configs ────────────────────────────────────────────────
# No extra configs for Juice Shop (JavaScript/TypeScript covered by base).
SEMGREP_EXTRA_CONFIGS=""
