# product.env — NodeGoat
#
# App-specific configuration for OWASP NodeGoat.
# Sourced by run_pipeline.sh.
#
# NodeGoat specifics:
#   • Requires a MongoDB sidecar.
#   • No official pre-built Docker Hub image — the image is built from the
#     repository Dockerfile during CI and tagged locally.
#   • Default port: 4000

# ── Target identity ──────────────────────────────────────────────────────
APP_NAME="nodegoat"
APP_URL="http://target-nodegoat:4000"
APP_PORT="4000"
CONTAINER_PORT="4000"

# ── Docker image ─────────────────────────────────────────────────────────
# Image is built from the app repo, not pulled from a registry.
DOCKER_IMAGE_NAME="nodegoat:ci-local"
DOCKER_IMAGE_SOURCE="build"

# ── Scanner defaults (overridden by workflow_dispatch inputs) ────────────
# Uses ${VAR:-default} so environment variables from the wrapper workflow
# take precedence over these defaults.
ENABLE_SEMGREP="${ENABLE_SEMGREP:-true}"
ENABLE_TRIVY_FS="${ENABLE_TRIVY_FS:-true}"
ENABLE_TRIVY_IMAGE="${ENABLE_TRIVY_IMAGE:-true}"
ENABLE_ZAP="${ENABLE_ZAP:-true}"

# ── Semgrep extra configs ────────────────────────────────────────────────
# NodeGoat is a Node.js app — add the nodejs rule pack.
SEMGREP_EXTRA_CONFIGS="p/nodejs"
