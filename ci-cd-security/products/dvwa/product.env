# product.env — DVWA
#
# App-specific configuration for Damn Vulnerable Web Application.
# Sourced by run_pipeline.sh.

# ── Target identity ──────────────────────────────────────────────────────
APP_NAME="dvwa"
APP_URL="http://dvwa:80"
APP_PORT="8081"
CONTAINER_PORT="80"

# ── Docker image ─────────────────────────────────────────────────────────
DOCKER_IMAGE_NAME="vulnerables/web-dvwa"
DOCKER_IMAGE_SOURCE="pull"

# ── Scanner defaults (overridden by workflow_dispatch inputs) ────────────
# Uses ${VAR:-default} so environment variables from the wrapper workflow
# take precedence over these defaults.
ENABLE_SEMGREP="${ENABLE_SEMGREP:-true}"
ENABLE_TRIVY_FS="${ENABLE_TRIVY_FS:-true}"
ENABLE_TRIVY_IMAGE="${ENABLE_TRIVY_IMAGE:-true}"
ENABLE_ZAP="${ENABLE_ZAP:-true}"

# ── Semgrep extra configs ────────────────────────────────────────────────
# No extra configs for DVWA (PHP covered by base).
SEMGREP_EXTRA_CONFIGS=""
